# ------------------------------------------
# Typer temp files
to_type.txt

# Speech_to_text
models/
temp/
*.wav
*.mp3

# OCRTool
tesseract/

# Rockyou - wordlist file (download separately)
rockyou.txt

# Django (expert-chatbot if included)
*.sqlite3
db.sqlite3
media/
staticfiles/


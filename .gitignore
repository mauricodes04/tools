# ------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg

# ------------------------------------------
# Virtual Environments
# ------------------------------------------
venv/
env/
.venv/
ENV/

# ------------------------------------------
# IDE / Editor
# ------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ------------------------------------------
# OS Generated
# ------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

